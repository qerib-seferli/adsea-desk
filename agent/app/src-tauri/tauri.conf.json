{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ADSEA Desk",
  "version": "0.1.0",
  "identifier": "com.adsea.desk",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    
      "windows": [
        {
          "title": "ADSEA Desk",
          "width": 1180,
          "height": 760,
          "minWidth": 980,
          "minHeight": 680,
          "resizable": true,
          "fullscreen": false
        }
      ]
    
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
